{
  // 💡 Inputs will be prompted on first server start,
  //    then stored securely by VS Code.
  "inputs": [
    {
      "type": "promptString",
      "id": "webex-api-key",
      "description": "Webex API Key",
      "password": true
    }
  ],
  "servers": {
    // Webex MCP Server for messaging API integration
    "webex": {
      "type": "stdio",
      "command": "${workspaceFolder}/build/webex-mcp-server",
      "args": [],
      "env": {
        "WEBEX_PUBLIC_WORKSPACE_API_KEY": "${input:webex-api-key}"
      }
    }
  }
}