{
  "chat.mcp.discovery.enabled": true,
  "mcp.servers": {
    "webex-mcp-docker": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "--env-file", "${workspaceFolder}/.env",
        "webex-mcp-server:latest"
      ]
    },
    "webex-mcp-compose": {
      "command": "docker-compose",
      "args": [
        "-f", "${workspaceFolder}/docker-compose.yml",
        "--profile", "stdio",
        "run",
        "--rm",
        "-T",
        "webex-mcp-stdio"
      ]
    },
    "webex-mcp-local": {
      "command": "go",
      "args": ["run", "${workspaceFolder}/main.go"],
      "env": {
        "WEBEX_PUBLIC_WORKSPACE_API_KEY": "${env:WEBEX_PUBLIC_WORKSPACE_API_KEY}"
      }
    },
    "webex-mcp-http": {
      "transport": {
        "type": "sse"
      },
      "url": "http://localhost:8084/sse"
    }
  }
}